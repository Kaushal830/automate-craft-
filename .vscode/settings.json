{
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.next/**": true,
    "**/.vercel/**": true,
    "**/node_modules/**": true,
    "**/out/**": true,
    "**/build/**": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/.vercel": true,
    "**/node_modules": true,
    "**/out": true,
    "**/build": true,
    "**/coverage": true
  },
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority"
  }
}
